<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.budgetbuilder.controller.NewItemDialogController"
      spacing="15" 
      style="-fx-padding: 20;" 
      prefWidth="600" 
      prefHeight="350">
    
    <Label text="Új Tétel Hozzáadása" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
    
    <Separator/>
    
    <HBox spacing="10">
        <Label text="Tétel típusa:" prefWidth="120" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="itemTypeCombo" HBox.hgrow="ALWAYS" 
                  promptText="Válassz tételtípust..."
                  prefHeight="30"
                  visibleRowCount="10"/>
    </HBox>
    
    <HBox spacing="10">
        <Label text="Alkategória:" prefWidth="120" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="subItemCombo" HBox.hgrow="ALWAYS" 
                  promptText="Előbb válassz tételtípust..."
                  prefHeight="30"
                  visibleRowCount="15"/>
    </HBox>
    
    <Separator/>
    
    <Region VBox.vgrow="ALWAYS"/>
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addBtn" text="✅ Hozzáadás" prefWidth="120" style="-fx-padding: 8px 16px;"/>
        <Button fx:id="cancelBtn" text="❌ Mégse" prefWidth="120" style="-fx-padding: 8px 16px;"/>
    </HBox>
</VBox>